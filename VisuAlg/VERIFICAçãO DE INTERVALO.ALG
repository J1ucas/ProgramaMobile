Algoritmo "Verificação de Intervalo"
//Leia um número e informe se ele está entre 10 e 50.





Var
num: inteiro




Inicio
escreva ("Qual o numero? ")
leia (num)
se (num >= 10) ou (num <= 50) entao
   escreva ("O numero está Entre o numero 10 e 50")
senão
escreva ("O numero não está entre o numero 10 e 50")

fimse


Fimalgoritmo