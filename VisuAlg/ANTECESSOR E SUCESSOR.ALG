Algoritmo "antecessor e sucessor"
//Leia um número inteiro e mostre seu antecessor e seu sucessor.
Var
N1: inteiro
N2: inteiro
N3: inteiro
Inicio
escreva ("Digite o seu numero: ")
leia (N1)
N2 <- (N1-1)
N3 <- (N1+1)
Escreva ("o sucessor é ",N3, " e o antecessor é ",N2,".")

Fimalgoritmo