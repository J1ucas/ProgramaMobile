Algoritmo "C·lculo de ¡rea"
//Leia a base e a altura de um ret‚ngulo (tipo real) e calcule a ·rea.
Var
Ba: real
Al: real
Resultado: real

Inicio
escreva ("Qual a altura da ‡rea? ")
leia (Al)
Escreva ("Qual a Base da ‡rea? ")
Leia (Ba)
Resultado <- (Al * Ba)
escreva ("O resultado da ‡rea È ",Resultado)

Fimalgoritmo