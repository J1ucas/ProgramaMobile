Algoritmo "Conversão de Idade"
//Leia a idade de uma pessoa em anos e exiba a idade em meses e em dias (considere 365 dias por ano).
Var
Ano: inteiro
Mes: inteiro
Dia: inteiro

Inicio
Escreva ("Qual a sua idade em anos? ")
leia (Ano)
Mes <- (Ano*12)
Dia <- (Ano*365)
Escreva ("A sua idade em Mêses é: ",Mes," e a sua idade em dias é ",Dia )


Fimalgoritmo